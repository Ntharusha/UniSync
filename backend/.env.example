PORT=3001
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/unisync?retryWrites=true&w=majority
MONGODB_URI_FALLBACK=mongodb://localhost:27017/unisync
REDIS_URL=redis://localhost:6379
# REQUIRED: Must be set in production — no insecure fallback
JWT_SECRET=change-me-in-production
NODE_ENV=development
# CORS: set to your frontend URL (dev: http://localhost:5173, prod: https://yourdomain.com)
FRONTEND_URL=http://localhost:5173
